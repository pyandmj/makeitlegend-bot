  "version": "1.0.0",
  "description": "Discord bot and automation server for Make It Legend — AI-powered pet portrait business command center",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "deploy-commands": "ts-node src/deploy-commands.ts",
    "setup-server": "ts-node src/setup-server.ts",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist"

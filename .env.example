# ─────────────────────────────────────────────────────────
# Make It Legend — Discord Bot Configuration
# ─────────────────────────────────────────────────────────

# Discord Bot Token (from Discord Developer Portal → Your App → Bot → Token)
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord Application Client ID (from Developer Portal → General Information)
DISCORD_CLIENT_ID=1476085430876373023

# Discord Server (Guild) ID — right-click server name → Copy Server ID
DISCORD_GUILD_ID=1476091316080349224

# Founder's Discord User ID — right-click your name → Copy User ID
FOUNDER_USER_ID=your_discord_user_id_here

# ─────────────────────────────────────────────────────────
# Manus API
# ─────────────────────────────────────────────────────────

# Manus API key for creating tasks programmatically
MANUS_API_KEY=your_manus_api_key_here

# Manus API base URL (optional)
MANUS_API_BASE_URL=https://api.manus.im

# ─────────────────────────────────────────────────────────
# Webhook Server Configuration
# ─────────────────────────────────────────────────────────

# Port for the Express webhook server
WEBHOOK_PORT=3000

# Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_secret_here

# Shared secret for Manus API webhooks
MANUS_WEBHOOK_SECRET=your_manus_webhook_secret_here

# Shared secret for website webhooks
WEBSITE_WEBHOOK_SECRET=your_website_webhook_secret_here

# ─────────────────────────────────────────────────────────
# Scheduling
# ─────────────────────────────────────────────────────────

# Daily briefing time (cron format, default: 8:00 AM)
BRIEFING_CRON=0 8 * * *

# Timezone for scheduled jobs
TIMEZONE=America/New_York

# ─────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────

# Log level: error, warn, info, debug
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────
# Environment
# ─────────────────────────────────────────────────────────

NODE_ENV=production
